{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ForgeSquad Audit Trail",
  "description": "Schema and template for the pipeline audit trail. Each pipeline run produces a single audit-trail.json file containing an ordered array of audit entries that record every significant action from start to completion.",
  "type": "array",
  "items": {
    "$ref": "#/definitions/AuditEntry"
  },
  "definitions": {
    "AuditEntry": {
      "type": "object",
      "required": [
        "entry_id",
        "sequence_number",
        "timestamp",
        "run_id",
        "squad",
        "phase",
        "step_id",
        "step_name",
        "agent_id",
        "agent_name",
        "action_type",
        "status"
      ],
      "properties": {
        "entry_id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for this audit entry (UUID v4)"
        },
        "sequence_number": {
          "type": "integer",
          "minimum": 1,
          "description": "Monotonically increasing counter starting at 1. Used to detect gaps or tampering."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 UTC timestamp of when the action occurred"
        },
        "run_id": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}-\\d{6}$",
          "description": "Pipeline run identifier in format YYYY-MM-DD-HHmmss"
        },
        "squad": {
          "type": "string",
          "description": "Squad code name (e.g., forge-engineering)"
        },
        "phase": {
          "type": "string",
          "enum": [
            "estimation",
            "requirements",
            "architecture",
            "planning",
            "implementation",
            "quality",
            "review",
            "documentation",
            "deployment",
            "sustaining"
          ],
          "description": "Pipeline phase in which the action occurred"
        },
        "step_id": {
          "type": "string",
          "description": "Pipeline step identifier (e.g., step-02, step-14)"
        },
        "step_name": {
          "type": "string",
          "description": "Human-readable step name"
        },
        "agent_id": {
          "type": "string",
          "description": "Identifier of the agent performing the action (or 'pipeline-runner' / 'user')"
        },
        "agent_name": {
          "type": "string",
          "description": "Display name of the agent (persona name)"
        },
        "action_type": {
          "type": "string",
          "enum": [
            "artifact_created",
            "artifact_reviewed",
            "artifact_approved",
            "artifact_rejected",
            "checkpoint_reached",
            "checkpoint_approved",
            "checkpoint_rejected",
            "handoff_initiated",
            "handoff_approved",
            "handoff_completed",
            "veto_triggered",
            "veto_resolved",
            "pipeline_started",
            "pipeline_completed"
          ],
          "description": "Type of action being recorded"
        },
        "artifact_path": {
          "type": ["string", "null"],
          "description": "Relative path to the artifact file within the run output folder. Required for artifact_* action types."
        },
        "artifact_hash_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 hex digest of the artifact content. Required for artifact_created and artifact_approved."
        },
        "status": {
          "type": "string",
          "enum": ["success", "failure", "pending", "skipped"],
          "description": "Outcome of the action"
        },
        "reviewer": {
          "type": ["string", "null"],
          "description": "Agent ID or 'user' who performed the review. Required for review/approval/rejection actions."
        },
        "approval_timestamp": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "ISO 8601 UTC timestamp of when approval was granted. Required for *_approved actions."
        },
        "related_entry_id": {
          "type": ["string", "null"],
          "format": "uuid",
          "description": "UUID of a related audit entry (e.g., linking an approval to its creation entry)"
        },
        "notes": {
          "type": ["string", "null"],
          "description": "Free-text field for additional context about the action"
        }
      },
      "additionalProperties": false
    }
  },
