{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "files.associations": {
    "*.agent.md": "markdown",
    "*.prompt.md": "markdown",
    "*.skill.md": "markdown",
    "squad.yaml": "yaml",
    "pipeline.yaml": "yaml",
    "config.yaml": "yaml"
  },
  "yaml.schemas": {},
  "markdown.preview.fontSize": 14,
  "search.exclude": {
    "**/_memory/**": true,
    "**/node_modules/**": true
  },
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true
  },
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": false
    }
  }
}
