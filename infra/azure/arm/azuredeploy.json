            { "name": "COSMOS_DB_DATABASE", "value": "forgesquad-db" },
            { "name": "STORAGE_ACCOUNT_NAME", "value": "[variables('storageAccountName')]" },
            { "name": "SERVICEBUS_NAMESPACE", "value": "[concat(variables('serviceBusName'), '.servicebus.windows.net')]" },
            { "name": "EVENTGRID_TOPIC_ENDPOINT", "value": "[reference(resourceId('Microsoft.EventGrid/topics', variables('eventGridTopicName'))).endpoint]" },
            { "name": "KEY_VAULT_URI", "value": "[reference(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))).vaultUri]" },
            { "name": "CONTAINER_APP_FQDN", "value": "[reference(resourceId('Microsoft.App/containerApps', concat('agent-runtime-', variables('suffix')))).configuration.ingress.fqdn]" }
          ]
        }
      }
    },
